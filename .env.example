# Required for PostgreSQL-backed reports. A local Docker/Postgres URL is suitable for development.
DATABASE_URL="postgresql://kavach:kavach@localhost:5432/kavach?schema=public"

# Required only when KAVACH_DEMO_MODE=false. Never expose this in NEXT_PUBLIC_* variables.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.6-sol"

# A deterministic, fully schema-validated audit fixture for demonstrations and local development.
KAVACH_DEMO_MODE="true"
KAVACH_MAX_UPLOAD_BYTES="10485760"
KAVACH_STORAGE_DIR="./storage"

# Optional. A zero-value means weather/coastal context is declared unavailable instead of invented.
KAVACH_ENVIRONMENT_DATA_URL=""
